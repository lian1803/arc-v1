# 위시켓 자동입찰 — 기존 cold_email .env 공유 가능
# cold_email_automation/.env 에 아래 항목 추가하면 됨

# Claude API (콜드메일과 동일)
ANTHROPIC_API_KEY=

# Gmail SMTP (콜드메일과 동일)
SMTP_USER=
SMTP_PASS=

# 알림 받을 이메일 (Lian 이메일)
LIAN_NOTIFY_EMAIL=gonggu.l.1803@gmail.com

# 포트폴리오/캘린들리 링크
PORTFOLIO_LINK=https://github.com/lian1803
CALENDLY_LINK=https://calendly.com/lian1803
