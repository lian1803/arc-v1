# 콜드메일 자동화 — 가입 0 (Lian 기존 자산만)

# 1. Claude API (ARC 기존 또는 Lian 보유)
ANTHROPIC_API_KEY=

# 2. Gmail SMTP/IMAP (Lian 기존 Gmail + App Password 5분 setup)
#    → setup_guide.md §1 참조 (2FA on → App Password 생성)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
SMTP_USER=          # 예: lian.dev@gmail.com (영업용 별 Gmail 권장)
SMTP_PASS=          # Gmail App Password 16자
SENDER_EMAIL=       # SMTP_USER 와 동일

# 3. 한국 정통법 — 수신거부 안내
# 옵션 A: 본문에 "회신으로 거부 가능" 박기 (가입 X, 자동)
# 옵션 B: Cloudflare Pages 무료 페이지 (가입 X, ARC 계정 사용)
OPT_OUT_REPLY_ADDRESS=  # SMTP_USER 와 동일 (회신 = 거부 의사)

# 4. Slack 알림 (옵션, 가입 X 면 비워둠)
SLACK_WEBHOOK_URL=
